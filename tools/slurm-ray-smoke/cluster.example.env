# Copy this file to a file such as cluster.my-slurm.env and edit values for one SLURM login alias.

CLUSTER_ALIAS=slurm-login
SCRATCH_ROOT=/shared/scratch/${USER}/ray-xcluster

NODES=2
NTASKS_PER_NODE=1
CPUS_PER_TASK=8
TIME_LIMIT=00:30:00
GPUS_PER_NODE=0

RUN_TEXT_SMOKES=1
RUN_PDF_PAGE_ELEMENTS_SMOKE=0
RUN_PDF_OCRV2_SMOKE=0
RUN_PDF_TEXT_EMBED_VDB_SMOKE=0
INSTALL_PAGE_ELEMENTS_EXTRAS=0
INSTALL_OCRV2_EXTRAS=0
INSTALL_LOCAL_EXTRAS=0
# INPUT_PDF=data/multimodal_test.pdf

RAY_PORT=6379
RAY_DASHBOARD_PORT=8265
RAY_CLIENT_SERVER_PORT=10001

SBATCH_SELECTOR=$(cat <<'SBATCH_SELECTOR_EOF'
#SBATCH --partition=debug
#SBATCH --account=research
SBATCH_SELECTOR_EOF
)
